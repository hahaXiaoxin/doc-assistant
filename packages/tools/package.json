{
  "name": "@doc-assistant/tools",
  "version": "0.6.0-beta.1",
  "private": true,
  "description": "Doc Assistant · Tools 层（本地工具注册中心，如页面提取、截图、OCR 等）",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@doc-assistant/memory": "workspace:*",
    "@doc-assistant/shared": "workspace:*",
    "@mozilla/readability": "^0.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "happy-dom": "^15.10.2",
    "vitest": "^2.1.4"
  }
}
