{
  "name": "doc-assistant",
  "version": "0.5.0",
  "private": true,
  "description": "智能阅读助手浏览器插件 · pnpm monorepo 根包",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.18.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @doc-assistant/extension dev",
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter @doc-assistant/extension build",
    "build:ext": "pnpm --filter @doc-assistant/extension build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts,.tsx,.js,.cjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.cjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,cjs,json,md,yaml,yml}\"",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "happy-dom": "^15.10.2",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
